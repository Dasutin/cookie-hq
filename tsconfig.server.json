{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "outDir": "dist/server",
    "rootDir": "src",
    "types": ["node"],
    "jsx": "react-jsx"
  },
  "include": ["src/server", "src/shared"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
